---
import type { NovelSummary } from "@/lib/r2";
import StatusBadge from "@/components/StatusBadge.astro";

interface Props {
  novel: NovelSummary;
  href: string;
}

const { novel, href } = Astro.props;

const initials = novel.title
  .split(" ")
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .join("");
---
<a
  href={href}
  style="background-color: var(--color-surface-alt); border: 1px solid var(--color-border);"
  class="group flex flex-col overflow-hidden rounded-lg transition-shadow hover:shadow-lg focus:outline-none"
>
  <!-- Cover Art -->
  <div
    class="relative aspect-[2/3] w-full overflow-hidden"
    style="background-color: var(--color-surface-alt);"
  >
    {novel.coverArtKey ? (
      <img
        src={`/api/r2/${novel.coverArtKey}`}
        alt={`Cover art for ${novel.title}`}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div
        class="flex h-full w-full items-center justify-center text-3xl font-bold"
        style="color: var(--color-text-muted);"
        aria-hidden="true"
      >
        {initials}
      </div>
    )}
  </div>

  <!-- Card Body -->
  <div class="flex flex-1 flex-col gap-2 p-3">
    <h3
      style="color: var(--color-text);"
      class="line-clamp-2 text-sm font-semibold leading-snug"
    >
      {novel.title}
    </h3>
    <p style="color: var(--color-text-muted);" class="text-xs">
      {novel.author}
    </p>
    <div class="mt-auto">
      <StatusBadge status={novel.status} />
    </div>
  </div>
</a>
