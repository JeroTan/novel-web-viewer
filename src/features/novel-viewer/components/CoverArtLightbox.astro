---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div
  id="cover-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Cover art viewer"
  tabindex="-1"
>
  <div id="lb-controls">
    <button class="lb-btn" id="lb-zoom-out" aria-label="Zoom out" type="button">−</button>
    <button class="lb-btn" id="lb-zoom-in" aria-label="Zoom in" type="button">+</button>
    <button class="lb-btn" id="lb-close" aria-label="Close lightbox" type="button">✕</button>
  </div>
  <div id="lb-stage">
    <div id="lb-img-wrap">
      <img src={src} alt={alt} id="lb-img" draggable="false" />
    </div>
  </div>
</div>

<style is:global>
  #cover-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.9);
    flex-direction: column;
    outline: none;
  }

  #cover-lightbox.lb-open {
    display: flex;
  }

  #lb-controls {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .lb-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.5);
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 1.25rem;
    cursor: pointer;
    user-select: none;
    line-height: 1;
    transition: background 0.15s, border-color 0.15s;
  }

  .lb-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.8);
  }

  #lb-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    cursor: grab;
    position: relative;
  }

  #lb-stage.lb-panning {
    cursor: grabbing;
  }

  #lb-img-wrap {
    transform-origin: center center;
    will-change: transform;
    user-select: none;
    touch-action: none;
  }

  #lb-img {
    display: block;
    max-width: min(90vw, 900px);
    max-height: 90vh;
    object-fit: contain;
    pointer-events: none;
    border-radius: 4px;
  }
</style>

<script>
  function initLightbox() {
    const overlay = document.getElementById("cover-lightbox") as HTMLElement;

    const stage = document.getElementById("lb-stage")!;
    const imgWrap = document.getElementById("lb-img-wrap")!;

    const MIN_SCALE = 1;
    const MAX_SCALE = 5;
    const ZOOM_STEP = 0.35;

    let scale = 1;
    let panX = 0;
    let panY = 0;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;

    function applyTransform() {
      imgWrap.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
    }

    function clamp(v: number, lo: number, hi: number) {
      return Math.min(Math.max(v, lo), hi);
    }

    function openLightbox() {
      scale = 1;
      panX = 0;
      panY = 0;
      applyTransform();
      overlay.classList.add("lb-open");
      document.body.style.overflow = "hidden";
      overlay.focus();
    }

    function closeLightbox() {
      overlay.classList.remove("lb-open");
      document.body.style.overflow = "";
    }

    // Wire all trigger buttons to open the lightbox
    document
      .querySelectorAll<HTMLElement>('[data-open-lightbox="cover-lightbox"]')
      .forEach((el) => el.addEventListener("click", openLightbox));

    document.getElementById("lb-close")?.addEventListener("click", closeLightbox);

    document.getElementById("lb-zoom-in")?.addEventListener("click", () => {
      scale = clamp(scale + ZOOM_STEP, MIN_SCALE, MAX_SCALE);
      applyTransform();
    });

    document.getElementById("lb-zoom-out")?.addEventListener("click", () => {
      scale = clamp(scale - ZOOM_STEP, MIN_SCALE, MAX_SCALE);
      if (scale <= MIN_SCALE) {
        scale = MIN_SCALE;
        panX = 0;
        panY = 0;
      }
      applyTransform();
    });

    // Backdrop click — only fires when clicking the stage itself, not children
    stage.addEventListener("click", (e) => {
      if (e.target === stage) closeLightbox();
    });

    // Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.classList.contains("lb-open")) {
        closeLightbox();
      }
    });

    // Scroll to zoom, pointer-centred
    stage.addEventListener(
      "wheel",
      (e) => {
        if (!overlay.classList.contains("lb-open")) return;
        e.preventDefault();

        const rect = stage.getBoundingClientRect();
        const mx = e.clientX - rect.left - rect.width / 2;
        const my = e.clientY - rect.top - rect.height / 2;

        const oldScale = scale;
        const delta = e.deltaY < 0 ? ZOOM_STEP : -ZOOM_STEP;
        scale = clamp(scale + delta, MIN_SCALE, MAX_SCALE);

        if (scale !== oldScale) {
          const factor = scale / oldScale;
          panX = mx - (mx - panX) * factor;
          panY = my - (my - panY) * factor;
          if (scale <= MIN_SCALE) {
            panX = 0;
            panY = 0;
          }
          applyTransform();
        }
      },
      { passive: false }
    );

    // Click-drag pan
    stage.addEventListener("mousedown", (e) => {
      if (scale <= MIN_SCALE) return;
      isDragging = true;
      dragStartX = e.clientX - panX;
      dragStartY = e.clientY - panY;
      stage.classList.add("lb-panning");
      e.preventDefault();
    });

    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      panX = e.clientX - dragStartX;
      panY = e.clientY - dragStartY;
      applyTransform();
    });

    document.addEventListener("mouseup", () => {
      if (!isDragging) return;
      isDragging = false;
      stage.classList.remove("lb-panning");
    });
  }

  initLightbox();
</script>
