---
// ReaderFormatStyle.astro
// Wraps injected HTML content (set:html) with explicit prose styles that
// survive Tailwind v4 Preflight resets. Uses <style is:global> scoped to
// a unique class so all child elements are styled correctly.
---
<div class="nvw-prose">
  <slot />
</div>

<style is:global>
  .nvw-prose {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .nvw-prose p {
    margin-top: 0;
    margin-bottom: 1.25em;
    font-size: 1rem;
    line-height: 1.8;
  }

  .nvw-prose h1,
  .nvw-prose h2,
  .nvw-prose h3,
  .nvw-prose h4,
  .nvw-prose h5,
  .nvw-prose h6 {
    color: var(--color-text);
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .nvw-prose h1 { font-size: 1.75rem; }
  .nvw-prose h2 { font-size: 1.375rem; }
  .nvw-prose h3 { font-size: 1.2rem; }
  .nvw-prose h4 { font-size: 1.1rem; }
  .nvw-prose h5,
  .nvw-prose h6 { font-size: 1rem; }

  .nvw-prose blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1em;
    margin: 1.5em 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .nvw-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .nvw-prose em {
    font-style: italic;
  }

  .nvw-prose strong {
    font-weight: 700;
  }

  .nvw-prose ul,
  .nvw-prose ol {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .nvw-prose ul {
    list-style-type: disc;
  }

  .nvw-prose ol {
    list-style-type: decimal;
  }

  .nvw-prose li {
    margin-bottom: 0.4em;
    line-height: 1.8;
  }

  .nvw-prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .nvw-prose a:hover {
    opacity: 0.8;
  }

  .nvw-prose code {
    font-family: ui-monospace, monospace;
    font-size: 0.875em;
    background-color: var(--color-surface-alt);
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .nvw-prose pre {
    background-color: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1em 1.25em;
    overflow-x: auto;
    margin-bottom: 1.25em;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .nvw-prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
</style>
