---
import type { Novel } from "@/lib/r2";
import StatusBadge from "@/components/StatusBadge.astro";
import GenreTag from "@/components/GenreTag.astro";
import CoverArtLightbox from "./components/CoverArtLightbox.astro";

interface Props {
  novel: Novel;
}

const { novel } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---
<header class="flex flex-col gap-6 md:flex-row md:items-start md:gap-8">
  <!-- Cover Art -->
  <div class="flex-shrink-0">
    {novel.coverArtKey ? (
      <button
        data-open-lightbox="cover-lightbox"
        type="button"
        aria-label={`View full cover art for ${novel.title}`}
        class="block cursor-zoom-in overflow-hidden rounded-lg p-0 transition-opacity hover:opacity-90 focus-visible:outline-2"
        style="border: 1px solid var(--color-border); background: transparent;"
      >
        <img
          src={`/api/r2/${novel.coverArtKey}`}
          alt={`Cover art for ${novel.title}`}
          class="h-64 w-44 object-cover shadow-md md:h-80 md:w-56"
        />
      </button>
    ) : (
      <div
        class="flex h-64 w-44 items-center justify-center rounded-lg text-4xl font-bold shadow-md md:h-80 md:w-56"
        style="background-color: var(--color-surface-alt); color: var(--color-text-muted); border: 1px solid var(--color-border);"
        aria-hidden="true"
      >
        {novel.title.split(" ").slice(0, 2).map((w) => w[0]?.toUpperCase() ?? "").join("")}
      </div>
    )}
  </div>

  <!-- Metadata -->
  <div class="flex flex-1 flex-col gap-3">
    <div class="flex flex-wrap items-center gap-3">
      <h1 style="color: var(--color-text);" class="text-2xl font-bold md:text-3xl">
        {novel.title}
      </h1>
      <StatusBadge status={novel.status} />
    </div>

    <p style="color: var(--color-text-muted);" class="text-base font-medium">
      by {novel.author}
    </p>

    {novel.description && (
      <p style="color: var(--color-text);" class="max-w-2xl text-sm leading-relaxed">
        {novel.description}
      </p>
    )}

    {novel.genre.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {novel.genre.map((g) => <GenreTag genre={g} />)}
      </div>
    )}

    <dl class="mt-2 flex flex-wrap gap-x-6 gap-y-1 text-xs" style="color: var(--color-text-muted);">
      <div class="flex gap-1">
        <dt>Language:</dt>
        <dd class="font-medium uppercase">{novel.language}</dd>
      </div>
      <div class="flex gap-1">
        <dt>Published:</dt>
        <dd>{formatDate(novel.publishedAt)}</dd>
      </div>
      <div class="flex gap-1">
        <dt>Updated:</dt>
        <dd>{formatDate(novel.updatedAt)}</dd>
      </div>
    </dl>
  </div>
</header>

{novel.coverArtKey && (
  <CoverArtLightbox
    src={`/api/r2/${novel.coverArtKey}`}
    alt={`Cover art for ${novel.title}`}
  />
)}
