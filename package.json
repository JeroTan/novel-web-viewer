{
  "name": "novel-web-viewer",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && vitest run && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "wrangler-types": "wrangler types",
    "wrangler-dev": "astro build && wrangler dev -- --ip 0.0.0.0 --port 8787",
    "deploy-development": "npx wrangler@latest deploy --env=\"development\"",
    "deploy-staging": "npx wrangler@latest deploy --env=\"staging\"",
    "deploy-production": "npx wrangler@latest deploy --env=\"production\"",
    "check": "astro check",
    "test": "vitest",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "jose": "^6.2.2",
    "lodash": "^4.18.1",
    "p-queue": "^9.1.1",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.2"
  }
}
